# App configuration
SERVICE_NAME=Backend Template Auth - Typescrypt
VERSION=local
LOG_LEVEL=DEBUG
PORT=3000

# DB configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=root
DB_PORT=3306
DB_NAME=db_name

DATABASE_URL=mysql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# JWT configuration
# Generate a strong secret and paste it here (min 32 chars, high entropy)
# Example (Unix): openssl rand -base64 48
JWT_SECRET=

# JWT Algorithm configuration
# - HS256: HMAC using SHA-256 hash algorithm
# - HS384: HMAC using SHA-384 hash algorithm
# - HS512: HMAC using SHA-512 hash algorithm
# - RS256: RSA using SHA-256 hash algorithm
# - RS384: RSA using SHA-384 hash algorithm
# - RS512: RSA using SHA-512 hash algorithm
# - ES256: ECDSA using SHA-256 hash algorithm
# - ES384: ECDSA using SHA-384 hash algorithm
# - ES512: ECDSA using SHA-512 hash algorithm
# - EdDSA: Edwards-curve Digital Signature Algorithm
JWT_ALGORITHM=RS512
JWT_EXPIRATION_MINUTES=60
JWT_REFRESH_EXPIRATION_MINUTES=10080
JWT_ISSUER=http://localhost:3000 
# this is the url of the Backend 
# - Desarrollo: http://localhost:3000
# - Staging: https://api.staging.tu-dominio.com
# - Producción: https://api.tu-dominio.com

JWT_AUDIENCE=http://localhost:3000
# this is the url of the Frontend
# - Desarrollo: http://localhost:4000
# - Staging: https://staging.tu-dominio.com
# - Producción: https://tu-dominio.com

# Optional for RS*/PS*/ES*/EdDSA algorithms (PEM format)
# JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# Cors configuration
ALLOWED_ORIGINS=all
# To allow originisyou could use 
# "all" to allow all origins
# "limited" to allow only the ones specified in the list located in src/config/cors_config.ts

# User configuration
SWAGGER_USER=admin
SWAGGER_PASSWORD=admin123

# AWS S3 configuration
AWS_DEFAULT_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=
AWS_S3_ROOT_PREFIX=

# Agregate development records to the database on startup
PRISMA_RUN_SEED=false